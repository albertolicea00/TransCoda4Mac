.build/
Package.resolved

# ------------------------------------------------------------------
# IDEs and editors
# ------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo

# ------------------------------------------------------------------
# FFmpeg binaries (vendored locally, never committed)
# ------------------------------------------------------------------
**/ffmpeg
**/ffprobe

# ------------------------------------------------------------------
# Logs, temp and local-only files
# ------------------------------------------------------------------
*.log
*.tmp
.env
.env.*
